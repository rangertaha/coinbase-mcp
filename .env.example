# coinbase-mcp environment configuration.
# Copy to .env and fill in your values:  cp .env.example .env
# (.env is gitignored; never commit real keys.)

# --- Optional: authentication ---
# Public market-data tools work WITHOUT credentials. Set both to enable
# authenticated account/order tools (CDP key from the Coinbase Developer Platform).
COINBASE_API_KEY=
COINBASE_API_SECRET=

# --- Optional: server behavior ---
# API base URL (default: https://api.coinbase.com).
# COINBASE_BASE_URL=https://api.coinbase.com

# Comma-separated toolset names to enable, or "all" (default).
COINBASE_TOOLSETS=all

# Optional: comma-separated individual tool names to allowlist.
# COINBASE_TOOLS=products_get,products_ticker

# "true" exposes only read-only tools.
COINBASE_READONLY=false
